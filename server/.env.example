# Copy to .env.local and fill in values for local development.
# .env.local is gitignored; .env can hold shared non-secret defaults.

SANCTUM_SECRET_KEY=change-me
SANCTUM_DEBUG=true
SANCTUM_ALLOWED_HOSTS=localhost,127.0.0.1

# Database: leave commented for SQLite, uncomment for PostgreSQL
# SANCTUM_DB_ENGINE=postgresql
# SANCTUM_DB_NAME=sanctum
# SANCTUM_DB_USER=sanctum
# SANCTUM_DB_PASSWORD=
# SANCTUM_DB_HOST=localhost
# SANCTUM_DB_PORT=5432

# CORS: comma-separated origins the frontend runs on.
# In debug mode, localhost:3000-3010 are allowed automatically.
# Only needed in production:
# SANCTUM_CORS_ORIGINS=https://sanctum.example.com
